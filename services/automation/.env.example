# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_BASE_URL=http://localhost:3000           # Public URL of this app (prod: https://your-app.vercel.app)

# ─── Meta WhatsApp Business API ───────────────────────────────────────────────
META_APP_SECRET=                              # App secret — used to verify x-hub-signature-256
META_VERIFY_TOKEN=                            # Arbitrary string you set; Meta sends it during webhook setup
META_PHONE_NUMBER_ID=                         # The phone number id (not the number itself)
META_ACCESS_TOKEN=                            # System user permanent access token (preferred over short-lived)
META_GRAPH_API_VERSION=v21.0

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=                                 # https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                    # Server-only. NEVER expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=                     # Same as SUPABASE_URL — exposed to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=                # Anon key — safe for browser, RLS protects data

# ─── Upstash QStash ───────────────────────────────────────────────────────────
QSTASH_TOKEN=                                 # For publishing jobs
QSTASH_CURRENT_SIGNING_KEY=                   # For verifying incoming job requests
QSTASH_NEXT_SIGNING_KEY=                      # Rotated key (Upstash provides both)

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001     # Start cheap; switch to claude-sonnet-4-6 if quality lacking

# Note: tenant-specific values (salon name, hours, address, services, etc.)
# live in the `tenants.config` JSONB column in Postgres — NOT in env vars.
# See supabase/migrations/0003_tenants_segment.sql for the seed.

# ─── Sentry (optional in dev) ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
